    "test": "vitest"
  },
  "dependencies": {
    "@morphos/shared": "workspace:*"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.2",
    "vitest": "^1.0.0"
  }
