{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@morphos/shared": ["packages/shared/src/index.ts"],
      "@morphos/shared/*": ["packages/shared/src/*"],
      "@morphos/ui": ["packages/ui/src/index.ts"],
      "@morphos/ui/*": ["packages/ui/src/*"],
      "@morphos/primitive-sdk": ["packages/primitive-sdk/src/index.ts"],
      "@morphos/primitive-sdk/*": ["packages/primitive-sdk/src/*"],
      "@morphos/adaptive-runtime": ["packages/adaptive-runtime/src/index.ts"],
      "@morphos/adaptive-runtime/*": ["packages/adaptive-runtime/src/*"],
      "@morphos/agent-core": ["packages/agent-core/src/index.ts"],
      "@morphos/agent-core/*": ["packages/agent-core/src/*"],
      "@morphos/mutation-core": ["packages/mutation-core/src/index.ts"],
      "@morphos/mutation-core/*": ["packages/mutation-core/src/*"],
      "@morphos/personalization-engine": ["packages/personalization-engine/src/index.ts"],
      "@morphos/personalization-engine/*": ["packages/personalization-engine/src/*"],
      "@morphos/protocol": ["packages/protocol/src/index.ts"],
      "@morphos/protocol/*": ["packages/protocol/src/*"],
      "@morphos/enterprise-audit": ["packages/enterprise-audit/src/index.ts"],
      "@morphos/enterprise-audit/*": ["packages/enterprise-audit/src/*"],
      "@morphos/self-optimizer": ["packages/self-optimizer/src/index.ts"],
      "@morphos/self-optimizer/*": ["packages/self-optimizer/src/*"],
      "@morphos/cross-platform-runtime": ["packages/cross-platform-runtime/src/index.ts"],
      "@morphos/cross-platform-runtime/*": ["packages/cross-platform-runtime/src/*"],
      "@morphos/predictive-mutations": ["packages/predictive-mutations/src/index.ts"],
      "@morphos/predictive-mutations/*": ["packages/predictive-mutations/src/*"],
      "@morphos/anomaly-detector": ["packages/anomaly-detector/src/index.ts"],
      "@morphos/anomaly-detector/*": ["packages/anomaly-detector/src/*"],
      "@morphos/plugin-system": ["packages/plugin-system/src/index.ts"],
      "@morphos/plugin-system/*": ["packages/plugin-system/src/*"]
    }
  },
  "include": ["packages", "apps"],
  "exclude": ["node_modules", "dist", "build"]
}
